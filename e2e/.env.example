# Copy to .env and fill in values. Never commit .env.
TEST_URL=https://doomzilla.duckdns.org

# Dedicated e2e organizer (test.organizer on mattermost-test)
ORGANIZER_USERNAME=test.organizer
ORGANIZER_PASSWORD=change-me

# Non-organizer member for gate tests (api-smoke resets via organizer if login fails)
NON_ORGANIZER_USERNAME=testuser.beta
# Use single quotes if password contains $ or special shell characters
NON_ORGANIZER_PASSWORD=''

# Pre-seeded member for list/reset/remove tests
MEMBER_USERNAME=testuser.alpha
